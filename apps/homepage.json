{
  "id": "homepage",
  "name": "Homepage",
  "description": "A highly customisable dashboard. Auto-configured to link all your apps.",
  "category": "dashboard",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/homepage.png",
  "image": "ghcr.io/gethomepage/homepage:latest",
  "ports": [
    {
      "host": 3000,
      "container": 3000,
      "protocol": "tcp",
      "label": "Dashboard",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "homepage",
      "container_path": "/app/config",
      "label": "Dashboard config"
    }
  ],
  "environment": {
    "standard_linuxserver": false,
    "extra_vars": []
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [],
  "conflicts_with": [],
  "preflight_checks": [],
  "homepage_integration": {
    "href": "http://localhost:3000",
    "description": "Home Dashboard",
    "icon": "homepage.png"
  },
  "tags": [
    "dashboard"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "Homepage auto-discovers your HomeStack services \u2014 no config needed",
        "type": "info"
      },
      {
        "instruction": "Customise widgets and layout by editing files in the homepage config directory",
        "type": "info"
      },
      {
        "instruction": "Bookmark http://YOUR_IP:3000 as your home lab landing page",
        "type": "info"
      }
    ],
    "web_url_path": "/",
    "docs_url": "https://gethomepage.dev/latest/"
  },
  "web_port": 3000
}
