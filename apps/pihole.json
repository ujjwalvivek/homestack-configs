{
  "id": "pihole",
  "name": "Pi-hole",
  "description": "DNS-level ad and tracker blocking for your entire network.",
  "category": "network",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/pi-hole.png",
  "image": "pihole/pihole:latest",
  "ports": [
    {
      "host": 53,
      "container": 53,
      "protocol": "udp",
      "label": "DNS",
      "conflicts_with": []
    },
    {
      "host": 53,
      "container": 53,
      "protocol": "tcp",
      "label": "DNS (TCP)",
      "conflicts_with": []
    },
    {
      "host": 8080,
      "container": 80,
      "protocol": "tcp",
      "label": "Admin UI",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "pihole/etc-pihole",
      "container_path": "/etc/pihole",
      "label": "Pi-hole config"
    },
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "pihole/etc-dnsmasq.d",
      "container_path": "/etc/dnsmasq.d",
      "label": "DNS config"
    }
  ],
  "environment": {
    "standard_linuxserver": false,
    "extra_vars": [
      {
        "key": "WEBPASSWORD",
        "env_key": "PIHOLE_WEBPASSWORD",
        "generate_secret": true,
        "description": "Pi-hole admin panel password"
      }
    ]
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [],
  "conflicts_with": [],
  "preflight_checks": [
    {
      "id": "systemd_resolved",
      "description": "systemd-resolved must release port 53"
    },
    {
      "id": "port_53_free",
      "description": "Port 53 UDP must be free on the host"
    }
  ],
  "homepage_integration": {
    "href": "http://localhost:8080/admin",
    "description": "Network Ad Blocker",
    "icon": "pi-hole.png",
    "widget": {
      "type": "pihole",
      "url": "http://pihole:80",
      "key": "PIHOLE_API_KEY"
    }
  },
  "tags": [
    "network",
    "dns",
    "adblock"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "Open Pi-hole web UI. Login password is the value of PIHOLE_WEBPASSWORD from your .env file. Enter it in the 'Password' field and click 'Log in'",
        "type": "info"
      },
      {
        "instruction": "To block ads network-wide: log into your router's admin panel (usually 192.168.1.1). Find DNS settings (often under DHCP or Internet/WAN). Set the Primary DNS server to this server's IP address. Save and reboot your router. All devices on your network will now use Pi-hole",
        "type": "info"
      },
      {
        "instruction": "In Pi-hole: go to Settings (gear icon, left sidebar) \u2192 API tab \u2192 click 'Show API token' \u2192 click the button to reveal and copy the token string",
        "type": "info"
      },
      {
        "instruction": "Paste the Pi-hole API token",
        "type": "input",
        "env_key": "PIHOLE_API_KEY",
        "api_validate_url": "/admin/api.php?summary",
        "api_header_format": "X-Pi-Hole-Token: {key}"
      }
    ],
    "web_url_path": "/admin",
    "docs_url": "https://docs.pi-hole.net/"
  },
  "web_port": 8080
}
