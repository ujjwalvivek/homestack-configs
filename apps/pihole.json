{
  "id": "pihole",
  "name": "Pi-hole",
  "description": "DNS-level ad and tracker blocking for your entire network.",
  "category": "network",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/pi-hole.png",
  "image": "pihole/pihole:latest",
  "ports": [
    {
      "host": 53,
      "container": 53,
      "protocol": "udp",
      "label": "DNS",
      "conflicts_with": []
    },
    {
      "host": 53,
      "container": 53,
      "protocol": "tcp",
      "label": "DNS (TCP)",
      "conflicts_with": []
    },
    {
      "host": 8080,
      "container": 80,
      "protocol": "tcp",
      "label": "Admin UI",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "pihole/etc-pihole",
      "container_path": "/etc/pihole",
      "label": "Pi-hole config"
    },
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "pihole/etc-dnsmasq.d",
      "container_path": "/etc/dnsmasq.d",
      "label": "DNS config"
    }
  ],
  "environment": {
    "standard_linuxserver": false,
    "extra_vars": [
      {
        "key": "FTLCONF_webserver_api_password",
        "env_key": "PIHOLE_WEBPASSWORD",
        "generate_secret": true,
        "description": "Pi-hole admin panel password (Pi-hole v6)"
      }
    ]
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [],
  "conflicts_with": [],
  "preflight_checks": [
    {
      "id": "systemd_resolved",
      "description": "systemd-resolved must release port 53"
    },
    {
      "id": "port_53_free",
      "description": "Port 53 UDP must be free on the host"
    }
  ],
  "homepage_integration": {
    "href": "http://localhost:8080/admin",
    "description": "Network Ad Blocker",
    "icon": "pi-hole.png",
    "widget": {
      "type": "pihole",
      "url": "http://pihole:80",
      "key": "PIHOLE_WEBPASSWORD"
    }
  },
  "tags": [
    "network",
    "dns",
    "adblock"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "Open Pi-hole web UI and use the admin password shown in the Pi-hole Login box below.",
        "type": "info"
      },
      {
        "instruction": "To block ads network-wide: log into your router's admin panel (usually 192.168.1.1). Find DNS settings (often under DHCP or LAN) and set the primary DNS to this server's IP address. All devices on your network will then use Pi-hole for DNS",
        "type": "info"
      },
      {
        "instruction": "Pi-hole v6 uses session-based authentication. No API token is needed \u2014 HomeStack validates using your admin password automatically",
        "type": "info"
      }
    ],
    "web_url_path": "/admin",
    "docs_url": "https://docs.pi-hole.net/"
  },
  "web_port": 8080
}
