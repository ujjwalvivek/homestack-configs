{
  "id": "plex",
  "name": "Plex",
  "description": "Stream your media library anywhere. Hardware transcoding supported.",
  "category": "media",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/plex.png",
  "image": "lscr.io/linuxserver/plex:latest",
  "ports": [
    {
      "host": 32400,
      "container": 32400,
      "protocol": "tcp",
      "label": "Web UI",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "plex",
      "container_path": "/config",
      "label": "Plex config & metadata"
    },
    {
      "host_path_key": "MEDIA_DIR",
      "host_subpath": "movies",
      "container_path": "/data/media/movies",
      "label": "Movies library"
    },
    {
      "host_path_key": "MEDIA_DIR",
      "host_subpath": "tv",
      "container_path": "/data/media/tv",
      "label": "TV library"
    },
    {
      "host_path_key": "MEDIA_DIR",
      "host_subpath": "music",
      "container_path": "/data/media/music",
      "label": "Music library"
    }
  ],
  "environment": {
    "standard_linuxserver": true,
    "extra_vars": [
      {
        "key": "PLEX_CLAIM",
        "env_key": "PLEX_CLAIM",
        "generate_secret": false,
        "user_provided": true,
        "description": "Plex claim token from https://plex.tv/claim (valid 4 minutes)"
      }
    ]
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [],
  "conflicts_with": [
    "jellyfin"
  ],
  "devices": [
    "/dev/dri:/dev/dri"
  ],
  "preflight_checks": [],
  "homepage_integration": {
    "href": "http://localhost:32400/web",
    "description": "Media Server",
    "icon": "plex.png",
    "widget": {
      "type": "plex",
      "url": "http://plex:32400",
      "key": "PLEX_API_KEY"
    }
  },
  "tags": [
    "media",
    "streaming",
    "transcoding"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "Sign in with your Plex account (or create one at plex.tv). You MUST claim the server within 5 minutes of first start. If it says 'Not Available', check that PLEX_CLAIM is set in .env (get a claim token from https://www.plex.tv/claim/)",
        "type": "info"
      },
      {
        "instruction": "Name your server (e.g. 'HomeStack'). Click Next. Add libraries: click 'Add Library' \u2192 Type: Movies \u2192 click 'Add Folder' \u2192 browse to /data/media/movies \u2192 click Add. Repeat for TV Shows \u2192 /data/media/tv. Click 'Done'",
        "type": "info"
      },
      {
        "instruction": "To get your Plex token: open any media item \u2192 click \u22ef (three dots) \u2192 Get Info \u2192 View XML. In the URL, copy the value after X-Plex-Token=. Or visit https://www.plex.tv/claim/ while signed in",
        "type": "info"
      },
      {
        "instruction": "Paste your Plex API token",
        "type": "input",
        "env_key": "PLEX_API_KEY"
      }
    ],
    "web_url_path": "/web",
    "docs_url": "https://support.plex.tv/"
  },
  "web_port": 32400
}
