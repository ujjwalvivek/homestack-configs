{
  "id": "sonarr",
  "name": "Sonarr",
  "description": "Automatic TV show downloading and organisation.",
  "category": "media",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/sonarr.png",
  "image": "lscr.io/linuxserver/sonarr:latest",
  "ports": [
    {
      "host": 8989,
      "container": 8989,
      "protocol": "tcp",
      "label": "Web UI",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "sonarr",
      "container_path": "/config",
      "label": "Config"
    },
    {
      "host_path_key": "DOWNLOADS_DIR",
      "host_subpath": "",
      "container_path": "/downloads",
      "label": "Download client output"
    },
    {
      "host_path_key": "MEDIA_DIR",
      "host_subpath": "",
      "container_path": "/tv",
      "label": "TV library"
    }
  ],
  "environment": {
    "standard_linuxserver": true,
    "extra_vars": []
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [],
  "conflicts_with": [],
  "preflight_checks": [],
  "homepage_integration": {
    "href": "http://localhost:8989",
    "description": "TV Manager",
    "icon": "sonarr.png",
    "widget": {
      "type": "sonarr",
      "url": "http://sonarr:8989",
      "key": "SONARR_API_KEY"
    }
  },
  "tags": [
    "media",
    "automation",
    "tv"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "First login will ask you to set up authentication. Select 'Forms (Login Page)' for Authentication Method. Enter a username and password. Click Save",
        "type": "info"
      },
      {
        "instruction": "HomeStack will add /tv as the root folder and connect qBittorrent automatically right after you paste a valid API key. If you later want a different layout, you can change it in Settings \u2192 Media Management and Settings \u2192 Download Clients.",
        "type": "info"
      },
      {
        "instruction": "Go to Settings \u2192 General \u2192 under 'Security', find the API Key field. Click the copy icon to copy it",
        "type": "info"
      },
      {
        "instruction": "Paste the Sonarr API key",
        "type": "input",
        "env_key": "SONARR_API_KEY",
        "api_validate_url": "/api/v3/system/status",
        "api_header_format": "X-Api-Key: {key}"
      }
    ],
    "web_url_path": "/",
    "docs_url": "https://wiki.servarr.com/sonarr"
  },
  "web_port": 8989
}
