{
  "id": "jellyfin",
  "name": "Jellyfin",
  "description": "Free open-source media server. Stream movies and TV to any device.",
  "category": "media",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/jellyfin.png",
  "image": "lscr.io/linuxserver/jellyfin:latest",
  "ports": [
    {
      "host": 8096,
      "container": 8096,
      "protocol": "tcp",
      "label": "Web UI",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "jellyfin",
      "container_path": "/config",
      "label": "Config & database"
    },
    {
      "host_path_key": "MEDIA_DIR",
      "host_subpath": "",
      "container_path": "/media",
      "label": "Media library"
    }
  ],
  "environment": {
    "standard_linuxserver": true,
    "extra_vars": []
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [],
  "conflicts_with": [
    "plex"
  ],
  "preflight_checks": [],
  "homepage_integration": {
    "href": "http://localhost:8096",
    "description": "Media Server",
    "icon": "jellyfin.png",
    "widget": {
      "type": "jellyfin",
      "url": "http://jellyfin:8096",
      "key": "JELLYFIN_API_KEY"
    }
  },
  "tags": [
    "media",
    "streaming"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "Create your admin account: choose a username and password. Select your preferred language and metadata language. Click Next",
        "type": "info"
      },
      {
        "instruction": "Add media libraries: click 'Add Media Library' \u2192 Content Type: Movies \u2192 click + next to Folders \u2192 type /media/movies \u2192 click OK. Repeat for TV Shows \u2192 /media/tv. Click Next \u2192 Finish",
        "type": "info"
      },
      {
        "instruction": "Create API key: go to Dashboard (admin panel, left sidebar) \u2192 API Keys \u2192 click + \u2192 name it 'homestack' \u2192 click OK. Copy the key shown",
        "type": "info"
      },
      {
        "instruction": "Paste the Jellyfin API key",
        "type": "input",
        "env_key": "JELLYFIN_API_KEY",
        "api_validate_url": "/System/Info",
        "api_header_format": "Authorization: MediaBrowser Token=\"{key}\""
      }
    ],
    "web_url_path": "/",
    "docs_url": "https://jellyfin.org/docs/"
  },
  "web_port": 8096
}
