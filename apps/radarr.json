{
  "id": "radarr",
  "name": "Radarr",
  "description": "Automatic movie downloading and organisation.",
  "category": "media",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/radarr.png",
  "image": "lscr.io/linuxserver/radarr:latest",
  "ports": [
    {
      "host": 7878,
      "container": 7878,
      "protocol": "tcp",
      "label": "Web UI",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "radarr",
      "container_path": "/config",
      "label": "Config"
    },
    {
      "host_path_key": "DOWNLOADS_DIR",
      "host_subpath": "",
      "container_path": "/downloads",
      "label": "Download client output"
    },
    {
      "host_path_key": "MEDIA_DIR",
      "host_subpath": "",
      "container_path": "/movies",
      "label": "Movie library"
    }
  ],
  "environment": {
    "standard_linuxserver": true,
    "extra_vars": []
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [],
  "conflicts_with": [],
  "preflight_checks": [],
  "homepage_integration": {
    "href": "http://localhost:7878",
    "description": "Movie Manager",
    "icon": "radarr.png",
    "widget": {
      "type": "radarr",
      "url": "http://radarr:7878",
      "key": "RADARR_API_KEY"
    }
  },
  "tags": [
    "media",
    "automation",
    "movies"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "First login will ask you to set up authentication. Select 'Forms (Login Page)' for Authentication Method. Enter a username and password. Click Save",
        "type": "info"
      },
      {
        "instruction": "Go to Settings (left sidebar) \u2192 Media Management \u2192 scroll down to 'Root Folders' \u2192 click 'Add Root Folder' \u2192 type /movies \u2192 click OK. This tells Radarr where to store your movie files",
        "type": "info"
      },
      {
        "instruction": "Go to Settings \u2192 Download Clients \u2192 click the + button \u2192 select 'qBittorrent'. Set: Host = qbittorrent, Port = 8081, Username = admin, Password = adminadmin (or the password you set during qBittorrent setup). Click 'Test' (must show green checkmark) \u2192 click Save",
        "type": "info"
      },
      {
        "instruction": "Go to Settings \u2192 General \u2192 under 'Security', find the API Key field. Click the copy icon next to it to copy the key",
        "type": "info"
      },
      {
        "instruction": "Paste the Radarr API key",
        "type": "input",
        "env_key": "RADARR_API_KEY",
        "api_validate_url": "/api/v1/system/status",
        "api_header_format": "X-Api-Key: {key}"
      }
    ],
    "web_url_path": "/",
    "docs_url": "https://wiki.servarr.com/radarr"
  },
  "web_port": 7878
}
