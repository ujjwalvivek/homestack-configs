{
  "id": "prowlarr",
  "name": "Prowlarr",
  "description": "Unified indexer manager that syncs with Sonarr, Radarr, and other *arr apps.",
  "category": "media",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/prowlarr.png",
  "image": "lscr.io/linuxserver/prowlarr:latest",
  "ports": [
    {
      "host": 9696,
      "container": 9696,
      "protocol": "tcp",
      "label": "Web UI",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "prowlarr",
      "container_path": "/config",
      "label": "Prowlarr config"
    }
  ],
  "environment": {
    "standard_linuxserver": true,
    "extra_vars": []
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [],
  "conflicts_with": [],
  "preflight_checks": [],
  "homepage_integration": {
    "href": "http://localhost:9696",
    "description": "Indexer Manager",
    "icon": "prowlarr.png",
    "widget": {
      "type": "prowlarr",
      "url": "http://prowlarr:9696",
      "key": "PROWLARR_API_KEY"
    }
  },
  "tags": [
    "media",
    "indexer",
    "arr"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "First login will ask you to set up authentication. Select 'Forms (Login Page)'. Enter a username and password. Click Save",
        "type": "info"
      },
      {
        "instruction": "Add indexers: click Indexers (left sidebar) \u2192 Add Indexer \u2192 search for your preferred indexers (e.g. 1337x, RARBG, Nyaa). Click the indexer \u2192 click 'Test' \u2192 click Save. Add at least 2-3 indexers for best results",
        "type": "info"
      },
      {
        "instruction": "HomeStack will auto-connect Radarr, Sonarr, and Whisparr after you paste a valid Prowlarr API key, using the API keys you already saved earlier in the wizard.",
        "type": "info"
      },
      {
        "instruction": "Go to Settings \u2192 General \u2192 find the API Key. Click copy",
        "type": "info"
      },
      {
        "instruction": "Paste the Prowlarr API key",
        "type": "input",
        "env_key": "PROWLARR_API_KEY",
        "api_validate_url": "/api/v1/system/status",
        "api_header_format": "X-Api-Key: {key}"
      }
    ],
    "web_url_path": "/",
    "docs_url": "https://wiki.servarr.com/prowlarr"
  },
  "web_port": 9696
}
