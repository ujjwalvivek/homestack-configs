{
  "id": "overseerr",
  "name": "Overseerr",
  "description": "Media request management. Let friends request movies and TV shows.",
  "category": "media",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/overseerr.png",
  "image": "lscr.io/linuxserver/overseerr:latest",
  "ports": [
    {
      "host": 5055,
      "container": 5055,
      "protocol": "tcp",
      "label": "Web UI",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "overseerr",
      "container_path": "/config",
      "label": "Config"
    }
  ],
  "environment": {
    "standard_linuxserver": true,
    "extra_vars": []
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [
    "radarr",
    "sonarr",
    "jellyfin"
  ],
  "conflicts_with": [],
  "preflight_checks": [],
  "homepage_integration": {
    "href": "http://localhost:5055",
    "description": "Request Manager",
    "icon": "overseerr.png",
    "widget": {
      "type": "overseerr",
      "url": "http://overseerr:5055",
      "key": "OVERSEERR_API_KEY"
    }
  },
  "tags": [
    "media",
    "requests"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "Sign in with your Jellyfin or Plex account on first login",
        "type": "info"
      },
      {
        "instruction": "Connect your media server (Jellyfin or Plex) in Settings",
        "type": "info"
      },
      {
        "instruction": "Connect Radarr and Sonarr in Settings > Services",
        "type": "info"
      },
      {
        "instruction": "Go to Settings > General and copy the API Key",
        "type": "info"
      },
      {
        "instruction": "Paste the Overseerr API key",
        "type": "input",
        "env_key": "OVERSEERR_API_KEY"
      }
    ],
    "web_url_path": "/",
    "docs_url": "https://docs.overseerr.dev/"
  },
  "web_port": 5055
}
