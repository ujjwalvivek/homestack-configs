{
  "id": "home-assistant",
  "name": "Home Assistant",
  "description": "Open-source home automation platform. Controls 2000+ integrations from one dashboard.",
  "category": "automation",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/home-assistant.png",
  "image": "ghcr.io/home-assistant/home-assistant:stable",
  "network_mode": "host",
  "ports": [],
  "web_port": 8123,
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "home-assistant",
      "container_path": "/config",
      "label": "Home Assistant config"
    },
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "home-assistant/media",
      "container_path": "/media",
      "label": "Home Assistant media"
    }
  ],
  "environment": {
    "standard_linuxserver": false,
    "extra_vars": [
      {
        "key": "TZ",
        "env_key": "TZ",
        "generate_secret": false,
        "description": "Timezone"
      }
    ]
  },
  "devices": [],
  "privileged": false,
  "networks": [],
  "depends_on": [],
  "conflicts_with": [],
  "preflight_checks": [],
  "homepage_integration": {
    "href": "http://localhost:8123",
    "description": "Home Automation",
    "icon": "home-assistant.png",
    "widget": {
      "type": "homeassistant",
      "url": "http://localhost:8123",
      "key": "HASS_API_KEY"
    }
  },
  "tags": ["automation", "smart-home", "iot", "zigbee"],
  "setup_wizard": {
    "steps": [
      { "instruction": "Create your Home Assistant account (this becomes the owner account)", "type": "info" },
      { "instruction": "Set your home location and units", "type": "info" },
      { "instruction": "Home Assistant will auto-discover devices on your network", "type": "info" },
      { "instruction": "For Zigbee/Z-Wave USB devices: uncomment the 'devices:' lines in docker-compose.yml and add your USB path (e.g. /dev/ttyUSB0:/dev/ttyUSB0), then run: docker compose up -d", "type": "info" },
      { "instruction": "Go to Profile (bottom left) > Long-Lived Access Tokens > Create Token", "type": "info" },
      { "instruction": "Paste your Home Assistant API token", "type": "input", "env_key": "HASS_API_KEY" }
    ],
    "web_url_path": "/",
    "docs_url": "https://www.home-assistant.io/docs/"
  }
}
