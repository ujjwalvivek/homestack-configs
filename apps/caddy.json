{
  "id": "caddy",
  "name": "Caddy",
  "description": "Automatic HTTPS reverse proxy. Routes clean URLs to all your services with zero cert management.",
  "category": "infrastructure",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/caddy.png",
  "image": "caddy:2-alpine",
  "ports": [
    {
      "host": 80,
      "container": 80,
      "protocol": "tcp",
      "label": "HTTP",
      "conflicts_with": []
    },
    {
      "host": 443,
      "container": 443,
      "protocol": "tcp",
      "label": "HTTPS",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "caddy/data",
      "container_path": "/data",
      "label": "Caddy TLS certificates & persistent data"
    },
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "caddy/config",
      "container_path": "/config",
      "label": "Caddy auto-generated config"
    },
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "caddy/Caddyfile",
      "container_path": "/etc/caddy/Caddyfile",
      "label": "Caddyfile (generated by HomeStack)"
    }
  ],
  "environment": {
    "standard_linuxserver": false,
    "extra_vars": []
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [],
  "conflicts_with": [],
  "preflight_checks": [
    {
      "id": "port_80_free",
      "description": "Port 80 must be available for Caddy HTTP"
    },
    {
      "id": "port_443_free",
      "description": "Port 443 must be available for Caddy HTTPS"
    }
  ],
  "homepage_integration": {
    "href": "http://localhost:80",
    "description": "Reverse Proxy",
    "icon": "caddy.png"
  },
  "tags": [
    "infrastructure",
    "reverse-proxy",
    "https",
    "ssl"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "Caddy auto-configures itself from the generated Caddyfile",
        "type": "info"
      },
      {
        "instruction": "If you provided a domain, point your DNS A record to this server's public IP",
        "type": "info"
      },
      {
        "instruction": "Caddy will automatically provision Let's Encrypt TLS certificates",
        "type": "info"
      },
      {
        "instruction": "Access services via https://app.yourdomain.com instead of IP:port",
        "type": "info"
      }
    ],
    "web_url_path": "/",
    "docs_url": "https://caddyserver.com/docs/"
  },
  "web_port": 80
}
