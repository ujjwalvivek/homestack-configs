{
  "id": "whisparr",
  "name": "Whisparr",
  "description": "Automated adult content management. Sonarr fork with category-specific metadata.",
  "category": "media",
  "icon_url": "https://cdn.jsdelivr.net/gh/walkxcode/dashboard-icons/png/whisparr.png",
  "image": "ghcr.io/hotio/whisparr:latest",
  "ports": [
    {
      "host": 6969,
      "container": 6969,
      "protocol": "tcp",
      "label": "Web UI",
      "conflicts_with": []
    }
  ],
  "volumes": [
    {
      "host_path_key": "CONFIG_DIR",
      "host_subpath": "whisparr",
      "container_path": "/config",
      "label": "Whisparr config"
    },
    {
      "host_path_key": "MEDIA_DIR",
      "host_subpath": "",
      "container_path": "/data/media",
      "label": "Media library"
    },
    {
      "host_path_key": "DOWNLOADS_DIR",
      "host_subpath": "",
      "container_path": "/data/downloads",
      "label": "Downloads"
    }
  ],
  "environment": {
    "standard_linuxserver": false,
    "extra_vars": [
      {
        "key": "PUID",
        "env_key": "PUID",
        "generate_secret": false,
        "description": "User ID"
      },
      {
        "key": "PGID",
        "env_key": "PGID",
        "generate_secret": false,
        "description": "Group ID"
      },
      {
        "key": "TZ",
        "env_key": "TZ",
        "generate_secret": false,
        "description": "Timezone"
      }
    ]
  },
  "networks": [
    "homestack"
  ],
  "depends_on": [],
  "conflicts_with": [],
  "preflight_checks": [],
  "homepage_integration": {
    "href": "http://localhost:6969",
    "description": "Adult Media Manager",
    "icon": "whisparr.png",
    "widget": {
      "type": "whisparr",
      "url": "http://whisparr:6969",
      "key": "WHISPARR_API_KEY"
    }
  },
  "tags": [
    "media",
    "arr",
    "automation"
  ],
  "setup_wizard": {
    "steps": [
      {
        "instruction": "First login will ask you to set up authentication. Select 'Forms (Login Page)'. Enter a username and password. Click Save",
        "type": "info"
      },
      {
        "instruction": "Go to Settings \u2192 Media Management \u2192 Root Folders \u2192 Add Root Folder \u2192 type /data/media \u2192 click OK",
        "type": "info"
      },
      {
        "instruction": "Go to Settings \u2192 Download Clients \u2192 click + \u2192 select 'qBittorrent'. Set: Host = qbittorrent, Port = 8081, Username = admin, Password = (the password you set during qBittorrent setup). Click Test (must show green checkmark) \u2192 Save",
        "type": "info"
      },
      {
        "instruction": "Go to Settings \u2192 General \u2192 copy the API Key",
        "type": "info"
      },
      {
        "instruction": "Paste the Whisparr API key",
        "type": "input",
        "env_key": "WHISPARR_API_KEY",
        "api_validate_url": "/api/v1/system/status",
        "api_header_format": "X-Api-Key: {key}"
      }
    ],
    "web_url_path": "/",
    "docs_url": "https://wiki.servarr.com/whisparr"
  },
  "web_port": 6969
}
